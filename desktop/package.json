{
  "name": "blackcat-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop shell for blackcat write (Electron + Vite + React)",
  "main": "dist/desktop/src/main.js",
  "scripts": {
    "clean": "rimraf dist release",
    "predev": "npm run build:main",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:main\"",
    "dev:renderer": "npm run build:themes && vite",
    "dev:main": "cross-env NODE_ENV=development node scripts/start-electron.js",
    "watch:main": "tsc -p tsconfig.json --outDir dist --watch",
    "build": "npm run clean && npm run build:themes && npm run build:renderer && npm run build:main",
    "build:report": "BUNDLE_REPORT=true npm run build",
    "build:renderer": "vite build",
    "build:themes": "node scripts/build-theme-css.js",
    "build:main": "tsc -p tsconfig.json --outDir dist",
    "package": "npm run build && electron-builder --config electron-builder.yml --publish=never",
    "package:mac": "npm run build && electron-builder --config electron-builder.yml --mac --x64 --arm64 --publish=never",
    "package:win": "npm run build && electron-builder --config electron-builder.yml --win --x64 --publish=never",
    "package:linux": "npm run build && electron-builder --config electron-builder.yml --linux --x64 --publish=never",
    "lint": "echo \"(lint placeholder)\"",
    "test:smoke": "playwright test --config=playwright.config.ts --project=chromium"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@permaweb/aoconnect": "^0.0.93",
    "dexie": "^4.0.8",
    "electron": "^28.3.0",
    "electron-updater": "^6.1.8",
    "gsap": "^3.12.5",
    "lottie-web": "^5.12.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "three": "^0.165.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "@types/three": "^0.165.0",
    "@vitejs/plugin-react": "^5.0.3",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron-builder": "^24.13.3",
    "electron-notarize": "^1.2.2",
    "electronmon": "^2.0.4",
    "rimraf": "^5.0.5",
    "rollup-plugin-visualizer": "^5.14.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "vite-plugin-purgecss": "^0.2.13"
  }
}
