{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "types": ["node", "react", "react-dom"],
    "rootDirs": ["./src", "../src"]
  },
  "include": ["src/**/*", "../src/manifest/**/*"]
}
